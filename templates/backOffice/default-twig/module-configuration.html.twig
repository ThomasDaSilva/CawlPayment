{#
 # CAWL Payment - Back-office configuration (Thelia 3 / default-twig).
 # Rendered by CawlPayment\Hook\AdminHook::onModuleConfiguration.
 # Posts to the cawlpayment.admin.configure route as cawlpayment_configuration[...].
 #}
{% set d = 'cawlpayment' %}

{% if app.request.query.get('success') %}
    <div class="alert alert-success">{{ 'Configuration saved successfully'|trans({}, d) }}</div>
{% endif %}
{% if app.request.query.get('error') %}
    <div class="alert alert-danger">{{ app.request.query.get('error') }}</div>
{% endif %}

<div class="general-block-decorator">
    <div class="row">
        <div class="col-md-12 title title-without-tabs">
            <i class="glyphicon glyphicon-credit-card"></i>
            {{ 'CAWL Payment Configuration'|trans({}, d) }}
        </div>
    </div>

    <form method="post" action="{{ path('cawlpayment.admin.configure') }}" id="cawlpayment-config-form">
        <input type="hidden" name="cawlpayment_configuration[_token]" value="{{ form_token }}">
        <input type="hidden" name="cawlpayment_configuration[enabled_methods]" id="cawl-enabled-methods" value="{{ enabled_methods_list|join(',') }}">

        <ul class="nav nav-tabs" role="tablist">
            <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" data-toggle="tab" href="#cawl-credentials">{{ 'Credentials'|trans({}, d) }}</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" data-toggle="tab" href="#cawl-methods">{{ 'Payment methods'|trans({}, d) }}</a></li>
            <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" data-toggle="tab" href="#cawl-options">{{ 'Options'|trans({}, d) }}</a></li>
        </ul>

        <div class="tab-content" style="padding-top: 20px;">

            {# ============ CREDENTIALS ============ #}
            <div class="tab-pane fade show active" id="cawl-credentials" role="tabpanel">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">{{ 'Environment'|trans({}, d) }}</label>
                        <select name="cawlpayment_configuration[environment]" class="form-control form-select">
                            <option value="test" {{ config.environment == 'test' ? 'selected' }}>{{ 'Test (sandbox)'|trans({}, d) }}</option>
                            <option value="production" {{ config.environment == 'production' ? 'selected' }}>{{ 'Production'|trans({}, d) }}</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">{{ 'PSPID (merchant id)'|trans({}, d) }}</label>
                        <input type="text" name="cawlpayment_configuration[pspid]" class="form-control" value="{{ config.pspid }}">
                    </div>
                </div>

                <fieldset class="mb-3">
                    <legend class="h6">{{ 'Test credentials'|trans({}, d) }}</legend>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Test API Key'|trans({}, d) }}</label>
                            <input type="text" name="cawlpayment_configuration[api_key_test]" class="form-control" autocomplete="off"
                                   placeholder="{{ has_test_credentials ? '•••••• ' ~ ('configured, leave empty to keep'|trans({}, d)) : '' }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Test API Secret'|trans({}, d) }}</label>
                            <input type="password" name="cawlpayment_configuration[api_secret_test]" class="form-control" autocomplete="new-password"
                                   placeholder="{{ has_test_credentials ? '•••••• ' ~ ('configured, leave empty to keep'|trans({}, d)) : '' }}">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Test Webhook Key'|trans({}, d) }}</label>
                            <input type="text" name="cawlpayment_configuration[webhook_key_test]" class="form-control" value="{{ webhook_key_test }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Test Webhook Secret'|trans({}, d) }}</label>
                            <input type="password" name="cawlpayment_configuration[webhook_secret_test]" class="form-control" autocomplete="new-password"
                                   placeholder="{{ 'leave empty to keep'|trans({}, d) }}">
                        </div>
                    </div>
                </fieldset>

                <fieldset class="mb-3">
                    <legend class="h6">{{ 'Production credentials'|trans({}, d) }}</legend>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Prod API Key'|trans({}, d) }}</label>
                            <input type="text" name="cawlpayment_configuration[api_key_prod]" class="form-control" autocomplete="off"
                                   placeholder="{{ has_prod_credentials ? '•••••• ' ~ ('configured, leave empty to keep'|trans({}, d)) : '' }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Prod API Secret'|trans({}, d) }}</label>
                            <input type="password" name="cawlpayment_configuration[api_secret_prod]" class="form-control" autocomplete="new-password"
                                   placeholder="{{ has_prod_credentials ? '•••••• ' ~ ('configured, leave empty to keep'|trans({}, d)) : '' }}">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Prod Webhook Key'|trans({}, d) }}</label>
                            <input type="text" name="cawlpayment_configuration[webhook_key_prod]" class="form-control" value="{{ webhook_key_prod }}">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">{{ 'Prod Webhook Secret'|trans({}, d) }}</label>
                            <input type="password" name="cawlpayment_configuration[webhook_secret_prod]" class="form-control" autocomplete="new-password"
                                   placeholder="{{ 'leave empty to keep'|trans({}, d) }}">
                        </div>
                    </div>
                </fieldset>

                <div class="mb-3">
                    <label class="form-label">{{ 'Webhook URL (to declare in the CAWL portal)'|trans({}, d) }}</label>
                    <input type="text" class="form-control" readonly value="{{ webhook_url }}" onclick="this.select();">
                </div>

                <button type="button" class="btn btn-default" id="cawl-test-connection">
                    <i class="glyphicon glyphicon-refresh"></i> {{ 'Test API Connection'|trans({}, d) }}
                </button>
                <span id="cawl-test-result" style="margin-left: 10px;"></span>
            </div>

            {# ============ PAYMENT METHODS ============ #}
            <div class="tab-pane fade" id="cawl-methods" role="tabpanel">
                <p class="text-muted">{{ 'Select the payment methods to offer (availability depends on your CAWL contract).'|trans({}, d) }}</p>
                {% for categoryCode, category in methods_by_category %}
                    <fieldset class="mb-3">
                        <legend class="h6">{{ category.name }}</legend>
                        <div class="row">
                            {% for code, method in category.methods %}
                                <div class="col-md-4 mb-2">
                                    <div class="form-check">
                                        <input class="form-check-input cawl-method-checkbox" type="checkbox"
                                               id="cawl-method-{{ code }}" value="{{ code }}"
                                               {{ code in enabled_methods_list ? 'checked' }}>
                                        <label class="form-check-label" for="cawl-method-{{ code }}">{{ method.name }}</label>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    </fieldset>
                {% endfor %}
            </div>

            {# ============ OPTIONS ============ #}
            <div class="tab-pane fade" id="cawl-options" role="tabpanel">
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">{{ 'Capture mode'|trans({}, d) }}</label>
                        <select name="cawlpayment_configuration[capture_mode]" class="form-control form-select">
                            <option value="SALE" {{ config.capture_mode == 'SALE' ? 'selected' }}>{{ 'Immediate capture (SALE)'|trans({}, d) }}</option>
                            <option value="PRE_AUTHORIZATION" {{ config.capture_mode == 'PRE_AUTHORIZATION' ? 'selected' }}>{{ 'Pre-authorization'|trans({}, d) }}</option>
                        </select>
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">{{ 'Checkout description'|trans({}, d) }}</label>
                        <input type="text" name="cawlpayment_configuration[checkout_description]" class="form-control" value="{{ config.checkout_description }}">
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">{{ 'Minimum amount'|trans({}, d) }}</label>
                        <input type="number" step="0.01" name="cawlpayment_configuration[min_amount]" class="form-control" value="{{ config.min_amount }}">
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">{{ 'Maximum amount (0 = no limit)'|trans({}, d) }}</label>
                        <input type="number" step="0.01" name="cawlpayment_configuration[max_amount]" class="form-control" value="{{ config.max_amount }}">
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">{{ 'Test base URL (ngrok/tunnel for local testing)'|trans({}, d) }}</label>
                    <input type="text" name="cawlpayment_configuration[test_base_url]" class="form-control" value="{{ config.test_base_url }}" placeholder="https://xxxx.ngrok-free.app">
                </div>
                <div class="mb-3">
                    <label class="form-label">{{ 'Webhook IP whitelist (comma separated, CIDR allowed)'|trans({}, d) }}</label>
                    <input type="text" name="cawlpayment_configuration[webhook_ip_whitelist]" class="form-control" value="{{ config.webhook_ip_whitelist }}">
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="cawl-whitelist-enabled" name="cawlpayment_configuration[webhook_whitelist_enabled]" value="1" {{ config.webhook_whitelist_enabled == '1' ? 'checked' }}>
                    <label class="form-check-label" for="cawl-whitelist-enabled">{{ 'Enable webhook IP whitelist'|trans({}, d) }}</label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="cawl-enable-logging" name="cawlpayment_configuration[enable_logging]" value="1" {{ config.enable_logging == '1' ? 'checked' }}>
                    <label class="form-check-label" for="cawl-enable-logging">{{ 'Enable logging'|trans({}, d) }}</label>
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-primary">{{ 'Save configuration'|trans({}, d) }}</button>
        </div>
    </form>
</div>

<script>
(function () {
    var form = document.getElementById('cawlpayment-config-form');
    if (!form) return;

    // Sync method checkboxes into the hidden enabled_methods field.
    function syncMethods() {
        var checked = Array.prototype.slice
            .call(document.querySelectorAll('.cawl-method-checkbox:checked'))
            .map(function (cb) { return cb.value; });
        document.getElementById('cawl-enabled-methods').value = checked.join(',');
    }
    document.querySelectorAll('.cawl-method-checkbox').forEach(function (cb) {
        cb.addEventListener('change', syncMethods);
    });
    form.addEventListener('submit', syncMethods);

    // Test API connection (uses currently saved credentials).
    var testBtn = document.getElementById('cawl-test-connection');
    if (testBtn) {
        testBtn.addEventListener('click', function () {
            var result = document.getElementById('cawl-test-result');
            result.textContent = '…';
            fetch('{{ path('cawlpayment.admin.test_connection') }}', {
                method: 'POST',
                headers: {'X-Requested-With': 'XMLHttpRequest'},
                credentials: 'same-origin'
            })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (data.success) {
                        result.innerHTML = '<span class="text-success">✓ ' + (data.message || 'OK') + '</span>';
                    } else {
                        result.innerHTML = '<span class="text-danger">✗ ' + (data.message || data.error || 'Error') + '</span>';
                    }
                })
                .catch(function (e) {
                    result.innerHTML = '<span class="text-danger">✗ ' + e + '</span>';
                });
        });
    }
})();
</script>
